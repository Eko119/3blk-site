# Resend API key for the /api/contact route (server-only).
# Set in Vercel project env (Production) before deploy.
# Missing key → /api/contact throws at request-time only; build still succeeds.
RESEND_API_KEY=

# Optional: recipient inbox for contact form submissions.
# Falls back to SITE.contactEmail in src/lib/site.ts when unset.
CONTACT_TO_EMAIL=
